{
  "name": "@thinkwork/plugin-n8n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./src/manifest.ts",
    "./deployment/managed-app": "./src/deployment/managed-app.ts",
    "./deployment/image-build": "./src/deployment/image-build.ts",
    "./package-config": "./src/package-config.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "thinkworkPlugin": {
    "catalogPublication": "deferred",
    "reason": "THNK-50 U1 scaffolds the n8n package before the managed-app adapter and tenant service credential MCP auth contract exist. U7 publishes the final manifest."
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1"
  },
  "devDependencies": {
    "@thinkwork/deployment-runner": "workspace:*",
    "@thinkwork/plugin-catalog": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
