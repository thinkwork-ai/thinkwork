{
  "name": "@thinkwork/plugin-catalog",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./catalog": "./src/catalog.ts",
    "./contracts": "./src/contracts.ts",
    "./plugin-package": "./src/plugin-package.ts",
    "./plugins": "./src/registry/index.ts",
    "./registry": "./src/registry/index.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate:plugins": "tsx scripts/generate-plugin-registry.ts",
    "check:plugins": "tsx scripts/generate-plugin-registry.ts --check",
    "build:catalog": "tsx scripts/generate-plugin-registry.ts --check && tsx scripts/build-catalog.ts"
  },
  "dependencies": {
    "@thinkwork/plugin-company-brain": "workspace:*",
    "@thinkwork/plugin-lastmile": "workspace:*",
    "@thinkwork/plugin-plane": "workspace:*",
    "@thinkwork/plugin-twenty": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
