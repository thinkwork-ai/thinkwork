# Thinkwork Greenfield Deployment
#
# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars to version control.

stage      = "dev"
region     = "us-east-1"
account_id = "123456789012"  # your AWS account ID

# Database engine:
#   "aurora-serverless" — Aurora Serverless v2 (production, auto-scaling, deletion protection on)
#   "rds-postgres"      — Standard RDS PostgreSQL (dev/test, cheaper, deletion protection off)
database_engine = "rds-postgres"

# Memory:
#   AgentCore managed memory is always on — every agent gets automatic
#   per-turn retention with zero config. Uncomment the line below to
#   enable Hindsight as an optional add-on (adds an ECS+ALB service for
#   semantic + entity-graph + cross-encoder retrieval tools alongside the
#   built-in remember/recall/forget tools).
# enable_hindsight = true

# Managed applications:
#   Twenty CRM is optional. First enable should set both booleans true after
#   the deployment workflow has created the dedicated database URL secret and
#   encryption-key secret. Later disable should leave twenty_provisioned=true
#   and set twenty_runtime_enabled=false so CRM data/storage/cache are retained.
#   Full cleanup should set both booleans false through the Managed
#   Applications Destroy action so the deploy workflow can also drop the
#   dedicated database and delete Twenty secrets after Terraform teardown.
#
# twenty_provisioned                = false
# twenty_runtime_enabled            = false
# twenty_image_uri                  = "twentycrm/twenty@sha256:..."
# twenty_db_username                = "thinkwork_twenty"
# twenty_db_name                    = "thinkwork_twenty"
# twenty_db_url_secret_arn          = "arn:aws:secretsmanager:us-east-1:123456789012:secret:thinkwork/dev/twenty/db-url-..."
# twenty_encryption_key_secret_arn  = "arn:aws:secretsmanager:us-east-1:123456789012:secret:thinkwork/dev/twenty/encryption-key-..."
# twenty_public_url                 = "" # empty derives https://crm.<www_domain>
# twenty_certificate_arn            = "" # empty creates a dedicated crm.<www_domain> certificate
# twenty_email_from_address         = "" # empty derives noreply@ses_inbound_domain for SES SMTP
# twenty_email_from_name            = "ThinkWork CRM"
#
#   Kestra is optional. First enable should set both booleans true after the
#   deployment workflow has created the dedicated database password secret and
#   basic-auth service credential. Later disable should leave
#   kestra_provisioned=true and set kestra_runtime_enabled=false so
#   database/storage/secrets/ALB are retained. Full cleanup should set both
#   booleans false through the Managed Applications Destroy action so the
#   deploy workflow can also drop the dedicated database and delete Kestra
#   secrets after Terraform teardown.
#
# kestra_provisioned                = false
# kestra_runtime_enabled            = false
# kestra_image_uri                  = "kestra/kestra@sha256:..."
# kestra_db_username                = "thinkwork_kestra"
# kestra_db_name                    = "thinkwork_kestra"
# kestra_db_password_secret_arn     = "arn:aws:secretsmanager:us-east-1:123456789012:secret:thinkwork/dev/kestra/db-password-..."
# kestra_basic_auth_secret_arn      = "arn:aws:secretsmanager:us-east-1:123456789012:secret:thinkwork/dev/kestra/basic-auth-..."
# kestra_public_url                 = "" # empty derives https://orchestrate.<www_domain>
# kestra_certificate_arn            = "" # empty creates a dedicated orchestrate.<www_domain> certificate
# kestra_storage_bucket_name        = "" # empty derives a per-stage bucket name
# kestra_storage_force_destroy      = false
# kestra_allowed_public_cidr_blocks = ["0.0.0.0/0"]

# Database master password — use a strong password
db_password = "CHANGE_ME_strong_password_here"

# Google OAuth (optional — leave empty to skip Google social login)
# google_oauth_client_id     = ""
# google_oauth_client_secret = ""

# Pre-signup Lambda (optional — leave empty if not using custom pre-signup logic)
# pre_signup_lambda_zip = "./lambdas/pre-signup.zip"

# Lambda artifacts:
# - Source checkout deploys can set lambda_zips_dir after `pnpm build:lambdas`.
# - Enterprise deployment repos should upload release zips to their
#   customer-owned artifact bucket and set lambda_artifact_bucket/prefix.
# - Set require_lambda_artifacts=true in generated enterprise stage files so
#   Terraform fails before creating placeholder-only API handlers.
#
# lambda_zips_dir = "../../dist/lambdas"
# lambda_artifact_bucket   = "customer-thinkwork-release-artifacts"
# lambda_artifact_prefix   = "releases/v1.2.3/lambdas"
# require_lambda_artifacts = true

# Google Places API key (optional — leave empty to run compile pipeline
# without live place-hierarchy enrichment; records fall back to
# metadata-only rows and no country/city backing pages are auto-created).
#
# When set, terraform creates a SSM SecureString parameter at
# /thinkwork/<stage>/google-places/api-key and the wiki-compile Lambda
# reads it on cold start. Alternative: leave blank here and set the key
# manually after apply via:
#   aws ssm put-parameter --type SecureString --overwrite \
#     --name /thinkwork/<stage>/google-places/api-key --value <KEY>
# (terraform's lifecycle.ignore_changes on the value keeps your manual
# value from being overwritten on future applies.)
# google_places_api_key = ""

# Public website (apps/www) custom domain.
# Leave www_domain empty to skip the custom domain and serve on the raw
# CloudFront URL. When set, you must also provide cloudflare_zone_id below —
# the www-dns module creates the ACM cert, apex CNAME, and www→apex redirect.
#
# The Cloudflare API token is read from the CLOUDFLARE_API_TOKEN environment
# variable. NEVER put the token in this file.
# www_domain         = "thinkwork.ai"
# cloudflare_zone_id = "your-cloudflare-zone-id"

# Tenant-scoped Space email addresses (optional).
# Keep the legacy agents.thinkwork.ai domain configured until retirement
# notices are no longer needed, then add tenant slugs before announcing
# <space>@<tenant>.thinkwork.ai addresses. Terraform creates one SES receiving
# identity and delegated Route53 subzone per tenant slug, then publishes NS
# delegation records in the Cloudflare parent zone above.
#
# ses_inbound_domain = "agents.thinkwork.ai"
# ses_parent_domain = "thinkwork.ai"
# tenant_slugs      = ["dev"]
