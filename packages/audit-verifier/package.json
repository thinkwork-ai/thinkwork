{
  "name": "@thinkwork/audit-verifier",
  "version": "0.1.0",
  "description": "Standalone audit-evidence verifier for the Thinkwork compliance audit-event log. Re-derives Merkle anchors written to S3 (Object Lock) by the compliance-anchor Lambda and emits a structured JSON pass/fail report. Re-implementation of the RFC 6962 algorithm — does NOT import the writer.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "audit-verifier": "dist/bin/audit-verifier.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "echo 'lint: skipped (eslint not configured)'",
    "prepublishOnly": "pnpm build && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "commander": "^12.0.0",
    "p-limit": "^6.0.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thinkwork-ai/thinkwork.git",
    "directory": "packages/audit-verifier"
  },
  "homepage": "https://thinkwork.ai",
  "keywords": [
    "audit",
    "compliance",
    "merkle",
    "soc2",
    "object-lock",
    "verifier",
    "rfc6962"
  ]
}
