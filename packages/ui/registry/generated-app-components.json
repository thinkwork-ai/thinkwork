{
  "version": "generated-app-policy:v1",
  "description": "Approved generated-app component and import surface for Thinkwork Computer applets.",
  "components": [
    {
      "id": "button",
      "exportName": "Button",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "command",
      "replaces": ["button", "cta", "toolbar-action"],
      "allowedVariants": [
        "default",
        "secondary",
        "outline",
        "ghost",
        "destructive"
      ],
      "dependencies": ["@radix-ui/react-slot", "class-variance-authority"],
      "registryDependencies": [],
      "description": "Use for every clickable command or action. Do not render raw button elements.",
      "example": "import { Button } from \"@thinkwork/ui\";\n<Button type=\"button\" variant=\"outline\">Refresh</Button>"
    },
    {
      "id": "card",
      "exportName": "Card",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "panel",
      "replaces": ["card", "metric-card", "bordered-panel", "shadow-panel"],
      "allowedVariants": [],
      "dependencies": [],
      "registryDependencies": [],
      "description": "Use Card plus CardHeader/CardTitle/CardDescription/CardContent for framed panels and metric groups.",
      "example": "import { Card, CardContent, CardHeader, CardTitle } from \"@thinkwork/ui\";\n<Card><CardHeader><CardTitle>Pipeline</CardTitle></CardHeader><CardContent>{children}</CardContent></Card>"
    },
    {
      "id": "badge",
      "exportName": "Badge",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "status",
      "replaces": ["badge", "pill", "status-label", "tag"],
      "allowedVariants": ["default", "secondary", "outline", "destructive"],
      "dependencies": ["class-variance-authority"],
      "registryDependencies": [],
      "description": "Use for status labels, tags, and compact categorical markers.",
      "example": "import { Badge } from \"@thinkwork/ui\";\n<Badge variant=\"secondary\">At risk</Badge>"
    },
    {
      "id": "tabs",
      "exportName": "Tabs",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "tab-set",
      "replaces": ["tabs", "segmented-navigation", "plain-text-tab-list"],
      "allowedVariants": [],
      "dependencies": ["radix-ui"],
      "registryDependencies": [],
      "description": "Use Tabs, TabsList, TabsTrigger, and TabsContent for every tabbed view.",
      "example": "import { Tabs, TabsContent, TabsList, TabsTrigger } from \"@thinkwork/ui\";\n<Tabs defaultValue=\"summary\"><TabsList><TabsTrigger value=\"summary\">Summary</TabsTrigger></TabsList><TabsContent value=\"summary\">...</TabsContent></Tabs>"
    },
    {
      "id": "table",
      "exportName": "Table",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "table",
      "replaces": ["table", "thead", "tbody", "tr", "td", "th", "data-grid"],
      "allowedVariants": [],
      "dependencies": [],
      "registryDependencies": [],
      "description": "Use Table primitives for simple tabular data; use DataTable for sortable/scannable operational grids.",
      "example": "import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from \"@thinkwork/ui\";\n<Table><TableHeader><TableRow><TableHead>Name</TableHead></TableRow></TableHeader><TableBody><TableRow><TableCell>Acme</TableCell></TableRow></TableBody></Table>"
    },
    {
      "id": "data-table",
      "exportName": "DataTable",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "data-grid",
      "replaces": ["sortable-table", "filterable-table", "operational-grid"],
      "allowedVariants": [],
      "dependencies": ["@tanstack/react-table"],
      "registryDependencies": ["table"],
      "description": "Use for dense sortable/scannable business records and operational grids.",
      "example": "import { DataTable } from \"@thinkwork/ui\";\n<DataTable columns={columns} data={rows} />"
    },
    {
      "id": "select",
      "exportName": "Select",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "select",
      "replaces": ["select", "dropdown", "single-select"],
      "allowedVariants": [],
      "dependencies": ["radix-ui"],
      "registryDependencies": [],
      "description": "Use Select, SelectTrigger, SelectValue, SelectContent, and SelectItem for dropdown choices.",
      "example": "import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from \"@thinkwork/ui\";\n<Select><SelectTrigger><SelectValue placeholder=\"Stage\" /></SelectTrigger><SelectContent><SelectItem value=\"renewal\">Renewal</SelectItem></SelectContent></Select>"
    },
    {
      "id": "dropdown-menu",
      "exportName": "DropdownMenu",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "menu",
      "replaces": ["action-menu", "overflow-menu", "dropdown-actions"],
      "allowedVariants": [],
      "dependencies": ["radix-ui"],
      "registryDependencies": ["button"],
      "description": "Use for action menus and overflow command lists; use Select for choosing a persistent value.",
      "example": "import { Button, DropdownMenu, DropdownMenuContent, DropdownMenuItem, DropdownMenuTrigger } from \"@thinkwork/ui\";\n<DropdownMenu><DropdownMenuTrigger asChild><Button variant=\"ghost\">Actions</Button></DropdownMenuTrigger><DropdownMenuContent><DropdownMenuItem>Archive</DropdownMenuItem></DropdownMenuContent></DropdownMenu>"
    },
    {
      "id": "combobox",
      "exportName": "Combobox",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "combobox",
      "replaces": ["searchable-select", "autocomplete", "typeahead"],
      "allowedVariants": [],
      "dependencies": ["cmdk", "radix-ui"],
      "registryDependencies": ["button"],
      "description": "Use when a dropdown must be searchable or autocomplete-like.",
      "example": "import { Combobox } from \"@thinkwork/ui\";\n<Combobox options={options} value={value} onValueChange={setValue} placeholder=\"Select account\" />"
    },
    {
      "id": "form-controls",
      "exportName": "Input",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "form-control",
      "replaces": ["input", "textarea", "checkbox", "switch", "label"],
      "allowedVariants": [],
      "dependencies": ["@radix-ui/react-label"],
      "registryDependencies": ["select"],
      "description": "Use Label with Input, Textarea, Checkbox, Switch, or Select for all form rows.",
      "example": "import { Input, Label } from \"@thinkwork/ui\";\n<Label htmlFor=\"query\">Search</Label><Input id=\"query\" value={query} onChange={handleChange} />"
    },
    {
      "id": "dialog-sheet",
      "exportName": "Dialog",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "overlay",
      "replaces": ["dialog", "modal", "sheet", "drawer"],
      "allowedVariants": [],
      "dependencies": ["radix-ui"],
      "registryDependencies": [],
      "description": "Use Dialog or Sheet primitives for overlays; do not hand-roll fixed-position modals.",
      "example": "import { Dialog, DialogContent, DialogHeader, DialogTitle } from \"@thinkwork/ui\";\n<Dialog><DialogContent><DialogHeader><DialogTitle>Details</DialogTitle></DialogHeader></DialogContent></Dialog>"
    },
    {
      "id": "scroll-area",
      "exportName": "ScrollArea",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "scroll-container",
      "replaces": ["custom-scroll-container", "overflow-panel"],
      "allowedVariants": [],
      "dependencies": ["radix-ui"],
      "registryDependencies": [],
      "description": "Use for intentionally scrollable panes and long lists.",
      "example": "import { ScrollArea } from \"@thinkwork/ui\";\n<ScrollArea className=\"h-72\">{rows}</ScrollArea>"
    },
    {
      "id": "separator",
      "exportName": "Separator",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "divider",
      "replaces": ["hr", "border-divider"],
      "allowedVariants": [],
      "dependencies": ["radix-ui"],
      "registryDependencies": [],
      "description": "Use as the divider primitive instead of custom border-only separators.",
      "example": "import { Separator } from \"@thinkwork/ui\";\n<Separator />"
    },
    {
      "id": "tooltip",
      "exportName": "Tooltip",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "tooltip",
      "replaces": ["title-attribute", "custom-tooltip"],
      "allowedVariants": [],
      "dependencies": ["radix-ui"],
      "registryDependencies": [],
      "description": "Use TooltipProvider, Tooltip, TooltipTrigger, and TooltipContent for hover help.",
      "example": "import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from \"@thinkwork/ui\";\n<TooltipProvider><Tooltip><TooltipTrigger asChild><span>Info</span></TooltipTrigger><TooltipContent>Source detail</TooltipContent></Tooltip></TooltipProvider>"
    },
    {
      "id": "chart-container",
      "exportName": "ChartContainer",
      "importSpecifier": "@thinkwork/ui",
      "approvedForGeneratedApps": true,
      "role": "chart",
      "replaces": ["raw-recharts-wrapper", "chart-frame"],
      "allowedVariants": [],
      "dependencies": ["recharts"],
      "registryDependencies": [],
      "description": "Required wrapper for Recharts primitives. Recharts JSX outside ChartContainer is rejected.",
      "example": "import { ChartContainer } from \"@thinkwork/ui\";\nimport { LineChart, Line, XAxis, YAxis } from \"recharts\";\n<ChartContainer config={{ value: { label: \"Value\" } }}><LineChart data={rows}><XAxis dataKey=\"name\" /><YAxis /><Line dataKey=\"value\" /></LineChart></ChartContainer>"
    },
    {
      "id": "host-map",
      "exportName": "MapView",
      "importSpecifier": "@thinkwork/computer-stdlib",
      "approvedForGeneratedApps": true,
      "role": "map",
      "replaces": [
        "leaflet",
        "react-leaflet",
        "map-iframe",
        "custom-map-wrapper"
      ],
      "allowedVariants": [],
      "dependencies": ["leaflet"],
      "registryDependencies": [],
      "description": "The sole approved map surface for generated apps. Raw Leaflet, React-Leaflet, map iframes, and custom map wrappers are rejected.",
      "example": "import { MapView } from \"@thinkwork/computer-stdlib\";\n<MapView fit={{ type: \"auto\" }} markers={markers} />"
    },
    {
      "id": "kpi-strip",
      "exportName": "KpiStrip",
      "importSpecifier": "@thinkwork/computer-stdlib",
      "approvedForGeneratedApps": true,
      "role": "metric-summary",
      "replaces": ["metric-cards", "kpi-cards"],
      "allowedVariants": [],
      "dependencies": [],
      "registryDependencies": ["card"],
      "description": "Use for compact KPI summaries when the app has multiple headline metrics.",
      "example": "import { KpiStrip } from \"@thinkwork/computer-stdlib\";\n<KpiStrip items={kpis} />"
    }
  ],
  "packages": {
    "@thinkwork/ui": [
      "Badge",
      "Button",
      "Card",
      "CardContent",
      "CardDescription",
      "CardFooter",
      "CardHeader",
      "CardTitle",
      "ChartContainer",
      "ChartLegend",
      "ChartLegendContent",
      "ChartTooltip",
      "ChartTooltipContent",
      "Checkbox",
      "Combobox",
      "DataTable",
      "Dialog",
      "DialogContent",
      "DialogDescription",
      "DialogFooter",
      "DialogHeader",
      "DialogTitle",
      "DropdownMenu",
      "DropdownMenuContent",
      "DropdownMenuItem",
      "DropdownMenuTrigger",
      "Input",
      "Label",
      "ScrollArea",
      "Select",
      "SelectContent",
      "SelectItem",
      "SelectTrigger",
      "SelectValue",
      "Separator",
      "Sheet",
      "SheetContent",
      "SheetDescription",
      "SheetFooter",
      "SheetHeader",
      "SheetTitle",
      "Skeleton",
      "Spinner",
      "Switch",
      "Table",
      "TableBody",
      "TableCaption",
      "TableCell",
      "TableFooter",
      "TableHead",
      "TableHeader",
      "TableRow",
      "Tabs",
      "TabsContent",
      "TabsList",
      "TabsTrigger",
      "Textarea",
      "Tooltip",
      "TooltipContent",
      "TooltipProvider",
      "TooltipTrigger"
    ],
    "@thinkwork/computer-stdlib": [
      "AppHeader",
      "BarChart",
      "DataTable",
      "EvidenceList",
      "KpiStrip",
      "MapView",
      "RefreshBar",
      "RefreshStateTimeline",
      "SourceStatusList",
      "StackedBarChart",
      "formatCurrency",
      "formatDate"
    ],
    "recharts": [
      "Area",
      "AreaChart",
      "Bar",
      "BarChart",
      "CartesianGrid",
      "Cell",
      "Legend",
      "Line",
      "LineChart",
      "Pie",
      "PieChart",
      "ResponsiveContainer",
      "Tooltip",
      "XAxis",
      "YAxis"
    ]
  },
  "roles": {
    "button": "Button",
    "card": "Card",
    "badge": "Badge",
    "tabs": "Tabs",
    "table": "Table or DataTable",
    "dropdown": "Select, DropdownMenu, or Combobox",
    "form-control": "Label plus Input/Textarea/Select/Checkbox/Switch",
    "chart": "ChartContainer with Recharts children",
    "map": "MapView"
  }
}
