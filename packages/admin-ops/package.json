{
  "name": "@thinkwork/admin-ops",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Typed client functions for Thinkwork admin operations — shared by the CLI and the admin-ops MCP server.",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tenants": "./src/tenants.ts",
    "./admin-keys": "./src/admin-keys.ts",
    "./teams": "./src/teams.ts",
    "./agents": "./src/agents.ts",
    "./templates": "./src/templates.ts",
    "./users": "./src/users.ts",
    "./artifacts": "./src/artifacts.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
