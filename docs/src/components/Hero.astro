---
import BrainMark from "./BrainMark.astro";

const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline, actions = [] } = data.hero || {};
---

<div class="hero">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="hero-inner">
    <div class="hero-mark">
      <BrainMark size={160} title="ThinkWork" />
    </div>

    <div class="hero-copy">
      <h1 id="_top" data-page-title set:html={title} />
      {tagline && <div class="hero-tagline" set:html={tagline} />}
    </div>

    {actions.length > 0 && (
      <div class="hero-actions">
        {actions.map(({ link: href, text, variant }) => (
          <a href={href} class:list={["hero-btn", variant === "primary" ? "primary" : "secondary"]}>
            {text}
          </a>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 5rem 1.5rem 4rem;
  }

  @media (min-width: 50rem) {
    .hero {
      padding: 6rem 1.5rem 5rem;
    }
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-glow::before {
    content: "";
    position: absolute;
    left: 50%;
    top: -10%;
    width: 640px;
    height: 480px;
    transform: translateX(-50%);
    border-radius: 9999px;
    background: color-mix(in srgb, var(--sl-color-accent) 8%, transparent);
    filter: blur(120px);
  }

  .hero-glow::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 30%;
    width: 480px;
    height: 320px;
    transform: translateX(-50%);
    border-radius: 9999px;
    background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    filter: blur(100px);
  }

  .hero-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
  }

  .hero-mark {
    color: var(--sl-color-accent);
    filter: drop-shadow(0 0 48px color-mix(in srgb, var(--sl-color-accent) 35%, transparent));
    line-height: 0;
  }

  .hero-mark :global(svg) {
    width: 120px;
    height: 120px;
  }

  @media (min-width: 50rem) {
    .hero-mark :global(svg) {
      width: 160px;
      height: 160px;
    }
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  h1 {
    font-size: clamp(var(--sl-text-3xl), calc(0.25rem + 5vw), var(--sl-text-6xl));
    line-height: var(--sl-line-height-headings);
    font-weight: 600;
    color: var(--sl-color-white);
    letter-spacing: -0.02em;
  }

  .hero-tagline {
    font-size: clamp(var(--sl-text-base), calc(0.0625rem + 2vw), var(--sl-text-xl));
    color: var(--sl-color-gray-2);
    max-width: 42rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-size: var(--sl-text-base);
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }

  .hero-btn.primary {
    background: var(--sl-color-accent);
    color: var(--sl-color-black);
  }

  .hero-btn.primary:hover {
    background: var(--sl-color-accent-high);
  }

  .hero-btn.secondary {
    border: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-white);
    background: transparent;
  }

  .hero-btn.secondary:hover {
    border-color: var(--sl-color-gray-3);
    background: color-mix(in srgb, var(--sl-color-white) 5%, transparent);
  }
</style>
