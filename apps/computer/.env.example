# apps/computer dev env. Mirror values from your dev stack's Terraform outputs
# (the same set scripts/build-admin.sh writes for apps/admin's .env.production).
#
# Run `pnpm --filter @thinkwork/computer dev` after copying this to .env.local.
# Cognito sign-in requires `http://localhost:5180` and
# `http://localhost:5180/auth/callback` to be in the ThinkworkAdmin
# Cognito client's CallbackURLs / LogoutURLs — manual tfvars edit until the
# infra slice ships that change.

VITE_API_URL=
VITE_GRAPHQL_HTTP_URL=
VITE_GRAPHQL_URL=
VITE_GRAPHQL_API_KEY=
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
