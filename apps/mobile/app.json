{
  "expo": {
    "name": "ThinkWork",
    "slug": "thinkwork-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "primaryColor": "#000000",
    "newArchEnabled": true,
    "scheme": "thinkwork",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "userInterfaceStyle": "dark",
      "backgroundColor": "#000000",
      "supportsTablet": true,
      "bundleIdentifier": "ai.thinkwork.mobile",
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIUserInterfaceStyle": "Dark",
        "NSPhotoLibraryUsageDescription": "Allow ThinkWork to access your photos for attaching images to tickets.",
        "NSCameraUsageDescription": "Allow ThinkWork to take a photo (e.g. a business card) to send to your agent.",
        "NSMicrophoneUsageDescription": "Allow ThinkWork to use the microphone for voice input.",
        "NSSpeechRecognitionUsageDescription": "Allow ThinkWork to use speech recognition."
      }
    },
    "android": {
      "userInterfaceStyle": "dark",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.thinkwork.agent",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-system-ui",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "ios": {
            "backgroundColor": "#000000"
          },
          "android": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow ThinkWork to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow ThinkWork to use speech recognition."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#38bdf8"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ThinkWork to attach photos (e.g. a business card) to your agent.",
          "cameraPermission": "Allow ThinkWork to take a photo (e.g. a business card) to send to your agent."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ff3bfecf-778d-40b6-9215-6c853187413d"
      },
      "apiUrl": "https://api.thinkwork.ai"
    },
    "owner": "thinkwork-ai",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ff3bfecf-778d-40b6-9215-6c853187413d"
    }
  }
}
