{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_COGNITO_USER_POOL_ID": "<your-cognito-user-pool-id>",
        "EXPO_PUBLIC_COGNITO_CLIENT_ID": "<your-cognito-client-id>",
        "EXPO_PUBLIC_COGNITO_DOMAIN": "<your-cognito-domain>",
        "EXPO_PUBLIC_GRAPHQL_URL": "<your-graphql-http-url>",
        "EXPO_PUBLIC_GRAPHQL_API_KEY": "<your-appsync-api-key>",
        "EXPO_PUBLIC_GRAPHQL_WS_URL": "<your-appsync-ws-url>"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_COGNITO_USER_POOL_ID": "<your-cognito-user-pool-id>",
        "EXPO_PUBLIC_COGNITO_CLIENT_ID": "<your-cognito-client-id>",
        "EXPO_PUBLIC_COGNITO_DOMAIN": "<your-cognito-domain>",
        "EXPO_PUBLIC_GRAPHQL_URL": "<your-graphql-http-url>",
        "EXPO_PUBLIC_GRAPHQL_API_KEY": "<your-appsync-api-key>",
        "EXPO_PUBLIC_GRAPHQL_WS_URL": "<your-appsync-ws-url>"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
