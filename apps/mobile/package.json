  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "npm run css && expo start --web",
    "web:dev": "npm run css:watch & expo start --web",
    "css": "tailwindcss -i ./global.css -o ./public/styles.css --minify",
    "css:watch": "tailwindcss -i ./global.css -o ./public/styles.css --watch",
