---
import CapabilityShowcase from "./CapabilityShowcase.astro";
import { costControl } from "../lib/copy";
---

<CapabilityShowcase
  id="cost"
  tone="raised"
  eyebrow={costControl.eyebrow}
  headline={costControl.headline}
  lede={costControl.lede}
  features={costControl.features}
  imagePath={costControl.imagePath}
  imageAlt="ThinkWork admin analytics cost view showing per-agent spend time series and budget status"
  caption={costControl.caption}
  chromeLabel="admin · analytics"
/>
