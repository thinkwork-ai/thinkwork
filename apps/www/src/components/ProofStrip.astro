---
const points = [
  { label: "Five-command deploy", detail: "From clone to a live harness in your account." },
  { label: "Runs in your AWS", detail: "No SaaS control plane. Your boundary, your data." },
  { label: "Open source core", detail: "Inspect it, fork it, ship it." },
  { label: "Threads · Memory · Control", detail: "Built in, not bolted on." },
];
---

<section class="border-y border-white/5 bg-white/[0.015]">
  <div class="mx-auto grid max-w-6xl grid-cols-2 gap-px overflow-hidden px-0 md:grid-cols-4">
    {points.map((p) => (
      <div class="flex flex-col gap-1 border-r border-white/5 px-6 py-6 last:border-r-0 md:px-8 md:py-8">
        <p class="text-sm font-semibold text-white">{p.label}</p>
        <p class="text-xs text-slate-500 md:text-sm">{p.detail}</p>
      </div>
    ))}
  </div>
</section>
