---
import { proofStrip } from "../lib/copy";
---

<section class="relative border-t border-white/5 py-10 md:py-14">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand/25 to-transparent"></div>
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid grid-cols-2 gap-x-8 gap-y-6 sm:grid-cols-3 md:grid-cols-5">
      {proofStrip.map((p) => (
        <div class="flex flex-col gap-1.5">
          <div class="flex items-center gap-2">
            <span class="h-1 w-1 rounded-full bg-brand/80"></span>
            <p class="text-sm font-semibold text-slate-100">{p.label}</p>
          </div>
          <p class="text-xs leading-5 text-slate-500">{p.detail}</p>
        </div>
      ))}
    </div>
  </div>
</section>
