---
import SectionShell from "./SectionShell.astro";
import SectionHeader from "./SectionHeader.astro";
import { journey } from "../lib/copy";
---

<SectionShell id="journey" glow="center">
  <SectionHeader
    eyebrow={journey.eyebrow}
    headline={journey.headline}
    lede={journey.lede}
    align="center"
    width="wide"
  />

  <ol class="mt-14 grid gap-5 sm:grid-cols-2 md:grid-cols-4 md:gap-4">
    {journey.steps.map((s, i) => (
      <li class="group relative rounded-2xl border border-white/5 bg-white/[0.02] p-5 transition hover:border-white/10 hover:bg-white/[0.035]">
        {i < journey.steps.length - 1 && (
          <span
            aria-hidden="true"
            class="pointer-events-none absolute hidden md:block md:right-[-10px] md:top-1/2 md:h-px md:w-5 md:-translate-y-1/2 md:bg-gradient-to-r md:from-brand/40 md:to-transparent"
          ></span>
        )}
        <p class="font-mono text-[11px] tracking-[0.2em] text-brand/70">{s.n}</p>
        <h3 class="mt-3 text-sm font-semibold leading-snug text-slate-100">{s.title}</h3>
        <p class="mt-2 text-xs leading-5 text-slate-400">{s.lede}</p>
      </li>
    ))}
  </ol>
</SectionShell>
