---
import SectionShell from "./SectionShell.astro";
import SectionHeader from "./SectionHeader.astro";
import { journey } from "../lib/copy";
---

<SectionShell id="journey" glow="center">
  <SectionHeader
    eyebrow={journey.eyebrow}
    headline={journey.headline}
    lede={journey.lede}
    width="wide"
  />

  <ol class="mt-16 grid gap-4 md:grid-cols-2">
    {journey.steps.map((s) => (
      <li class="group relative rounded-2xl border border-white/5 bg-white/[0.02] p-7 transition hover:border-white/10 hover:bg-white/[0.035]">
        <div class="flex items-baseline gap-4">
          <p class="font-mono text-[11px] tracking-[0.18em] text-brand/60">{s.n}</p>
          <h3 class="text-lg font-semibold text-slate-100">{s.title}</h3>
        </div>
        <p class="mt-4 text-sm leading-6 text-slate-300">{s.lede}</p>
      </li>
    ))}
  </ol>
</SectionShell>
