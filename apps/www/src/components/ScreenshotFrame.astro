---
// One frame for every product screenshot on the page.
// Renders a styled SVG placeholder while `pending={true}` so the site ships
// polished before real captures land.

interface Props {
  src: string;
  alt: string;
  caption: string;
  variant?: "templates" | "cost" | "evals" | "dashboard" | "memory";
  chromeLabel?: string;
  pending?: boolean;
  accent?: boolean;
  aspect?: "16/10" | "16/9" | "4/3";
}

const {
  src,
  alt,
  caption,
  variant = "templates",
  chromeLabel,
  pending = false,
  accent = false,
  aspect = "16/10",
} = Astro.props;

const frameClass = accent
  ? "relative overflow-hidden rounded-2xl border border-brand/20 bg-[#05080d] shadow-[0_24px_60px_rgba(56,189,248,0.14)]"
  : "relative overflow-hidden rounded-2xl border border-white/10 bg-[#05080d] shadow-[0_24px_60px_rgba(0,0,0,0.45)]";

const aspectClass =
  aspect === "16/9" ? "aspect-[16/9]" : aspect === "4/3" ? "aspect-[4/3]" : "aspect-[16/10]";
---

<figure>
  <div class={frameClass}>
    <div class="flex items-center gap-2 border-b border-white/5 bg-white/[0.02] px-4 py-2.5">
      <span class="h-2.5 w-2.5 rounded-full bg-red-500/50"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/50"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-green-500/50"></span>
      {chromeLabel && (
        <span class="ml-3 font-mono text-[11px] text-slate-500">{chromeLabel}</span>
      )}
    </div>

    {pending ? (
      <div class:list={[aspectClass, "w-full"]}>
        {variant === "templates" && (
          <svg viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg" class="h-full w-full" preserveAspectRatio="xMidYMid slice">
