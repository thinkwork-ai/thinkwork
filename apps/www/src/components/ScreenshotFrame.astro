            <rect x="32" y="250" width="120" height="12" rx="3" fill="#38bdf8" opacity="0.7" />
            <rect x="32" y="282" width="736" height="1" fill="#1f2937" />
            <rect x="32" y="306" width="150" height="28" rx="6" fill="#0f1823" stroke="#38bdf8" stroke-width="1" opacity="0.6" />
            <rect x="196" y="306" width="150" height="28" rx="6" fill="#0f1823" stroke="#38bdf8" stroke-width="1" opacity="0.6" />
            <rect x="360" y="306" width="150" height="28" rx="6" fill="#0f1823" stroke="#38bdf8" stroke-width="1" opacity="0.6" />
            <rect x="32" y="360" width="360" height="10" rx="3" fill="#334155" />
