---
import SectionShell from "./SectionShell.astro";
import SectionHeader from "./SectionHeader.astro";
import ScreenshotFrame from "./ScreenshotFrame.astro";
import { memory } from "../lib/copy";
---

<SectionShell id="memory" glow="center">
  <SectionHeader
    eyebrow={memory.eyebrow}
    headline={memory.headline}
    lede={memory.lede}
  />

  <div class="mt-14 grid gap-10 lg:grid-cols-12 lg:items-start lg:gap-14">
    <div class="lg:col-span-7">
      <ScreenshotFrame
        src="/images/admin/memories-graph.png"
        alt="ThinkWork memories page showing an interactive knowledge-graph visualization of memory entities across agents"
        caption={memory.caption}
        chromeLabel="admin · memory graph"
        variant="memory"
        accent
      />
    </div>

    <div class="space-y-6 lg:col-span-5">
      <div class="rounded-2xl border border-white/5 bg-white/[0.025] p-6">
        <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.2em] text-brand/85">
          <span class="h-1 w-1 rounded-full bg-brand"></span>
          <span>Portable memory</span>
        </div>
        <ul class="mt-4 space-y-3">
          {memory.memoryPoints.map((p) => (
            <li class="flex gap-3 text-sm leading-6 text-slate-300">
              <span class="mt-2 h-1 w-1 flex-none rounded-full bg-brand/70"></span>
              <span>{p}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="rounded-2xl border border-white/5 bg-white/[0.025] p-6">
        <div class="flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.2em] text-brand/85">
          <span class="h-1 w-1 rounded-full bg-brand"></span>
          <span>Wiki Memories</span>
        </div>
        <ul class="mt-4 space-y-3">
          {memory.wikiPoints.map((p) => (
            <li class="flex gap-3 text-sm leading-6 text-slate-300">
              <span class="mt-2 h-1 w-1 flex-none rounded-full bg-brand/70"></span>
              <span>{p}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</SectionShell>
