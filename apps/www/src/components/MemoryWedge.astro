---
import { memory } from "../lib/copy";
---

<section id="memory" class="relative border-t border-white/5">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-[640px] overflow-hidden">
    <div class="absolute left-1/2 top-[-20%] h-[600px] w-[1100px] -translate-x-1/2 rounded-full bg-brand/6 blur-[160px]"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6 py-24 md:py-32">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand/90">{memory.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">
        {memory.headline}
      </h2>
      <p class="mt-5 text-lg text-slate-400 md:text-xl">
        {memory.lede}
      </p>
    </div>

    <figure class="mt-14">
      <div class="overflow-hidden rounded-2xl border border-brand/20 bg-[#05080d] shadow-[0_24px_60px_rgba(56,189,248,0.14)]">
        <img
          src="/images/admin/memories-graph.png"
          alt="ThinkWork memories page showing an interactive knowledge-graph visualization of memory entities across agents"
          loading="lazy"
          class="block h-auto w-full"
        />
      </div>
      <figcaption class="mt-3 text-center text-xs uppercase tracking-[0.2em] text-slate-600">
        {memory.caption}
      </figcaption>
    </figure>

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      <div class="rounded-2xl border border-brand/20 bg-gradient-to-br from-brand/[0.06] to-transparent p-8">
        <div class="flex items-center gap-3">
          <span class="flex h-9 w-9 items-center justify-center rounded-xl border border-brand/30 bg-brand/10 text-brand">
            <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
              <path d="M12 20a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
              <path d="M6 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
              <path d="M18 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
              <path d="M12 6v4M12 14v4M8 12h8" />
            </svg>
          </span>
          <h3 class="text-2xl font-bold">Portable memory</h3>
        </div>
        <ul class="mt-6 space-y-4">
          {memory.memoryPoints.map((p) => (
            <li class="flex gap-3 text-sm leading-6 text-slate-300">
              <span class="mt-2 h-1 w-1 flex-none rounded-full bg-brand"></span>
              <span>{p}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="rounded-2xl border border-brand/20 bg-gradient-to-br from-brand/[0.06] to-transparent p-8">
        <div class="flex items-center gap-3">
          <span class="flex h-9 w-9 items-center justify-center rounded-xl border border-brand/30 bg-brand/10 text-brand">
            <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16v4H4z" />
              <path d="M4 12h16v4H4z" />
              <path d="M4 20h10" />
            </svg>
          </span>
          <h3 class="text-2xl font-bold">Wiki Memories</h3>
        </div>
        <ul class="mt-6 space-y-4">
          {memory.wikiPoints.map((p) => (
            <li class="flex gap-3 text-sm leading-6 text-slate-300">
              <span class="mt-2 h-1 w-1 flex-none rounded-full bg-brand"></span>
              <span>{p}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
