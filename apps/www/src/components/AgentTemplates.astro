---
import ScreenshotFrame from "./ScreenshotFrame.astro";
import { agentTemplates } from "../lib/copy";
---

<section id="templates" class="border-t border-white/5">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center lg:gap-16">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand/90">{agentTemplates.eyebrow}</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">
          {agentTemplates.headline}
        </h2>
        <p class="mt-5 text-lg text-slate-400 md:text-xl">
          {agentTemplates.lede}
        </p>
        <ul class="mt-8 space-y-3">
          {agentTemplates.bullets.map((b) => (
            <li class="flex gap-3 text-sm leading-6 text-slate-300">
              <span class="mt-2 h-1 w-1 flex-none rounded-full bg-brand"></span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <ScreenshotFrame
          src={agentTemplates.imagePath}
          alt="ThinkWork admin agent-templates editor with tool allow-list, model pin, and guardrail picker"
          caption={agentTemplates.caption}
          variant="templates"
          pending
          accent
        />
      </div>
    </div>
  </div>
</section>
