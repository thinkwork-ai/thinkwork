---
import CapabilityShowcase from "./CapabilityShowcase.astro";
import { agentTemplates } from "../lib/copy";
---

<CapabilityShowcase
  id="templates"
  eyebrow={agentTemplates.eyebrow}
  headline={agentTemplates.headline}
  lede={agentTemplates.lede}
  bullets={agentTemplates.bullets}
  imagePath={agentTemplates.imagePath}
  imageAlt="ThinkWork admin agent-templates editor with tool allow-list, model pin, and guardrail picker"
  caption={agentTemplates.caption}
  chromeLabel="admin · agent-templates"
  accent
/>
