---
import BrainMark from "./BrainMark.astro";

const docsUrl = "https://docs.thinkwork.ai";
const githubUrl = "https://github.com/thinkwork-ai/thinkwork";
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-[#070a0f]/80 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-3">
      <BrainMark class="text-brand" size={44} title="ThinkWork" />
      <span class="text-2xl font-semibold tracking-tight">ThinkWork</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <a href="#system" class="text-sm text-slate-400 transition hover:text-white">System</a>
      <a href="#memory" class="text-sm text-slate-400 transition hover:text-white">Memory</a>
      <a href="#quick-start" class="text-sm text-slate-400 transition hover:text-white">Quick start</a>
      <a href={docsUrl} class="text-sm text-slate-400 transition hover:text-white">Docs</a>
      <a
        href={githubUrl}
        class="rounded-lg border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-white transition hover:border-white/20 hover:bg-white/10"
      >
        GitHub
      </a>
    </div>

    <button id="mobile-menu-btn" class="md:hidden text-slate-400 hover:text-white" aria-label="Menu">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-white/5 bg-[#070a0f] px-6 pb-6 md:hidden">
    <div class="flex flex-col gap-4 pt-4">
      <a href="#system" class="text-sm text-slate-400 hover:text-white">System</a>
      <a href="#memory" class="text-sm text-slate-400 hover:text-white">Memory</a>
      <a href="#quick-start" class="text-sm text-slate-400 hover:text-white">Quick start</a>
      <a href={docsUrl} class="text-sm text-slate-400 hover:text-white">Docs</a>
      <a href={githubUrl} class="rounded-lg border border-white/10 bg-white/5 px-4 py-2 text-center text-sm font-medium text-white">
        GitHub
      </a>
    </div>
  </div>
</header>

<script>
  document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
    document.getElementById("mobile-menu")?.classList.toggle("hidden");
  });
</script>
