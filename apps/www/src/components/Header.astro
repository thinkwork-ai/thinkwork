---
import BrainMark from "./BrainMark.astro";
import { external, nav } from "../lib/copy";

// Normalize so /cloud and /cloud/ both resolve to /cloud for comparison.
const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (href: string) => {
  const target = href.replace(/\/+$/, "") || "/";
  if (target === "/") return currentPath === "/";
  return currentPath === target || currentPath.startsWith(`${target}/`);
};
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-[#070a0f]/80 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-3">
      <BrainMark class="text-brand" size={44} title="ThinkWork" />
      <span class="text-2xl font-semibold tracking-tight">ThinkWork</span>
    </a>

    <div class="hidden items-center gap-7 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? "page" : undefined}
          class:list={[
            "text-sm transition",
            isActive(item.href)
              ? "font-semibold text-white"
              : "text-slate-400 hover:text-white",
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="mailto:hello@thinkwork.ai?subject=ThinkWork demo request"
        class="rounded-lg bg-brand px-4 py-2 text-sm font-semibold text-slate-950 shadow shadow-brand/20 transition hover:scale-[1.02] hover:bg-brand-300"
      >
        Request a demo
      </a>
    </div>

    <button id="mobile-menu-btn" class="md:hidden text-slate-400 hover:text-white" aria-label="Menu">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-white/5 bg-[#070a0f] px-6 pb-6 md:hidden">
    <div class="flex flex-col gap-4 pt-4">
      {nav.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? "page" : undefined}
          class:list={[
            "text-sm",
            isActive(item.href)
              ? "font-semibold text-white"
              : "text-slate-400 hover:text-white",
          ]}
        >
          {item.label}
        </a>
      ))}
      <a href="mailto:hello@thinkwork.ai?subject=ThinkWork demo request" class="rounded-lg bg-brand px-4 py-2 text-center text-sm font-semibold text-slate-950">
        Request a demo
      </a>
    </div>
  </div>
</header>

<script>
  document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
    document.getElementById("mobile-menu")?.classList.toggle("hidden");
  });
</script>
