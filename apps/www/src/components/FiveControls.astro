---
import { controls } from "../lib/copy";
---

<section id="controls" class="relative border-t border-white/5 bg-white/[0.015]">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-[520px] overflow-hidden">
    <div class="absolute left-1/2 top-[-20%] h-[520px] w-[1000px] -translate-x-1/2 rounded-full bg-brand/5 blur-[160px]"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6 py-24 md:py-32">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand/90">{controls.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">
        {controls.headline}
      </h2>
      <p class="mt-5 text-lg text-slate-400 md:text-xl">
        {controls.lede}
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
      {controls.items.map((item) => (
        <div class="flex flex-col gap-4 rounded-2xl border border-white/5 bg-white/[0.02] p-6 transition hover:border-white/10 hover:bg-white/[0.04]">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl border border-brand/30 bg-brand/10 text-brand">
            {item.icon === "aws" && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 17a4 4 0 0 1 .8-7.92A6 6 0 0 1 16.5 8.5 4.5 4.5 0 0 1 18 17H4Z" />
                <path d="M8 21l4-4 4 4" />
              </svg>
            )}
            {item.icon === "templates" && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="16" rx="2" />
                <path d="M3 9h18" />
                <path d="M9 14h8" />
                <path d="M9 17h5" />
                <circle cx="6.5" cy="15.5" r="1" />
              </svg>
            )}
            {item.icon === "admin" && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7" rx="1" />
                <rect x="14" y="3" width="7" height="7" rx="1" />
                <rect x="3" y="14" width="7" height="7" rx="1" />
                <rect x="14" y="14" width="7" height="7" rx="1" />
              </svg>
            )}
            {item.icon === "cost" && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 20V10" />
                <path d="M9 20V4" />
                <path d="M15 20v-8" />
                <path d="M21 20V7" />
              </svg>
            )}
            {item.icon === "evals" && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-11V5l-8-3-8 3v6c0 7 8 11 8 11Z" />
                <path d="m9 12 2 2 4-4" />
              </svg>
            )}
          </span>
          <div>
            <h3 class="text-base font-semibold">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-400">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
