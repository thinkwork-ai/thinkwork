---
import SectionShell from "./SectionShell.astro";
import SectionHeader from "./SectionHeader.astro";
import { controls } from "../lib/copy";
---

<SectionShell id="controls" tone="raised" glow="top">
  <SectionHeader
    eyebrow={controls.eyebrow}
    headline={controls.headline}
    lede={controls.lede}
    width="widest"
  />

  <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
    {controls.items.map((item, i) => (
      <div class="group relative flex flex-col gap-5 rounded-2xl border border-white/5 bg-white/[0.025] p-6 transition hover:border-brand/25 hover:bg-white/[0.04]">
        <div class="flex items-center justify-between">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl border border-brand/20 bg-brand/[0.08] text-brand transition group-hover:border-brand/40 group-hover:bg-brand/[0.12]">
            {item.icon === "aws" && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 17a4 4 0 0 1 .8-7.92A6 6 0 0 1 16.5 8.5 4.5 4.5 0 0 1 18 17H4Z" />
                <path d="m8 21 4-4 4 4" />
              </svg>
            )}
            {item.icon === "templates" && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="16" rx="2" />
                <path d="M3 9h18" />
                <path d="M9 14h8" />
                <path d="M9 17h5" />
                <circle cx="6.5" cy="15.5" r="1" fill="currentColor" />
              </svg>
            )}
            {item.icon === "admin" && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7" rx="1" />
                <rect x="14" y="3" width="7" height="7" rx="1" />
                <rect x="3" y="14" width="7" height="7" rx="1" />
                <rect x="14" y="14" width="7" height="7" rx="1" />
              </svg>
            )}
            {item.icon === "cost" && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 20V10" />
                <path d="M9 20V4" />
                <path d="M15 20v-8" />
                <path d="M21 20V7" />
              </svg>
            )}
            {item.icon === "evals" && (
              <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-11V5l-8-3-8 3v6c0 7 8 11 8 11Z" />
                <path d="m9 12 2 2 4-4" />
              </svg>
            )}
          </span>
          <span class="font-mono text-[11px] tracking-[0.18em] text-brand/50">0{i + 1}</span>
        </div>
        <div>
          <h3 class="text-[15px] font-semibold text-slate-100">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-400">{item.desc}</p>
        </div>
      </div>
    ))}
  </div>
</SectionShell>
