---
import SectionShell from "./SectionShell.astro";
import SectionHeader from "./SectionHeader.astro";
import { ownership } from "../lib/copy";
---

<SectionShell id="ownership" glow="top">
  <SectionHeader
    eyebrow={ownership.eyebrow}
    headline={ownership.headline}
    lede={ownership.lede}
    width="wide"
  />

  <dl class="mt-14 grid grid-cols-1 border-y border-white/5 sm:grid-cols-2 md:grid-cols-5 md:divide-x md:divide-white/5">
    {ownership.points.map((p) => (
      <div class="border-b border-white/5 px-6 py-8 last:border-b-0 md:border-b-0">
        <dt class="font-mono text-[11px] uppercase tracking-[0.22em] text-brand/70">
          {p.title}
        </dt>
        <dd class="mt-3 text-lg font-semibold leading-7 text-slate-100">
          {p.desc}
        </dd>
      </div>
    ))}
  </dl>
</SectionShell>
