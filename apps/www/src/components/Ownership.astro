---
import SectionShell from "./SectionShell.astro";
import SectionHeader from "./SectionHeader.astro";
import { ownership } from "../lib/copy";
---

<SectionShell id="ownership" glow="top">
  <SectionHeader
    eyebrow={ownership.eyebrow}
    headline={ownership.headline}
    lede={ownership.lede}
    align="center"
    width="wide"
  />

  <ul class="mt-14 mx-auto max-w-3xl divide-y divide-white/5 rounded-2xl border border-white/5 bg-white/[0.02]">
    {ownership.points.map((p) => (
      <li class="flex items-baseline gap-6 px-6 py-5">
        <p class="w-24 shrink-0 font-mono text-[11px] uppercase tracking-[0.22em] text-brand/70">
          {p.title}
        </p>
        <p class="text-base leading-7 text-slate-200">{p.desc}</p>
      </li>
    ))}
  </ul>
</SectionShell>
