---
import SectionShell from "./SectionShell.astro";
import SectionHeader from "./SectionHeader.astro";
import ScreenshotFrame from "./ScreenshotFrame.astro";

interface Feature {
  title: string;
  desc: string;
}

interface Props {
  id: string;
  tone?: "default" | "raised";
  eyebrow: string;
  headline: string;
  lede: string;
  features: Feature[];
  imagePath: string;
  imageAlt: string;
  caption: string;
  chromeLabel?: string;
  accent?: boolean;
}

const {
  id,
  tone = "default",
  eyebrow,
  headline,
  lede,
  features,
  imagePath,
  imageAlt,
  caption,
  chromeLabel,
  accent = false,
} = Astro.props;
---

<SectionShell id={id} tone={tone} glow="top">
  <SectionHeader
    eyebrow={eyebrow}
    headline={headline}
    lede={lede}
    align="center"
    width="wide"
  />

  <div class="mt-14">
    <ScreenshotFrame
      src={imagePath}
      alt={imageAlt}
      caption={caption}
      chromeLabel={chromeLabel}
      accent={accent}
    />
  </div>

  <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {features.map((f, i) => (
      <div class="group relative flex flex-col gap-3 rounded-2xl border border-white/5 bg-white/[0.025] p-6 transition hover:border-brand/25 hover:bg-white/[0.04]">
        <div class="flex items-center justify-between">
          <span class="inline-flex h-6 items-center rounded-full border border-brand/25 bg-brand/[0.08] px-2 font-mono text-[10px] font-semibold tracking-[0.2em] text-brand/90">
            0{i + 1}
          </span>
          <span class="h-px flex-1 ml-3 bg-white/5 group-hover:bg-brand/20 transition"></span>
        </div>
        <h3 class="mt-1 text-[15px] font-semibold text-slate-100">{f.title}</h3>
        <p class="text-sm leading-6 text-slate-400">{f.desc}</p>
      </div>
    ))}
  </div>
</SectionShell>
