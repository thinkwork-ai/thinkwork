---
import { systemModel } from "../lib/copy";
---

<section id="system" class="border-t border-white/5 bg-white/[0.015]">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand/90">{systemModel.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">
        {systemModel.headline}
      </h2>
      <p class="mt-5 text-lg text-slate-400 md:text-xl">
        {systemModel.lede}
      </p>
    </div>

    <div class="relative mt-14">
      <div class="pointer-events-none absolute inset-0 rounded-3xl border border-brand/20 bg-brand/[0.03]"></div>
      <div class="relative p-6 md:p-8">
        <div class="mb-6 flex items-center justify-between">
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-brand/90">{systemModel.controlLabel}</span>
          <span class="text-xs text-slate-500">{systemModel.controlDetail}</span>
        </div>
        <div class="grid gap-4 md:grid-cols-4">
          {systemModel.nodes.map((n, i) => (
            <div class="relative rounded-2xl border border-white/10 bg-[#0a0f16] p-6">
              <div class="flex items-center gap-2 text-xs font-mono text-brand/70">
                <span>0{i + 1}</span>
                <span class="h-px flex-1 bg-white/10"></span>
              </div>
              <h3 class="mt-3 text-xl font-semibold">{n.title}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-400">{n.desc}</p>
            </div>
          ))}
        </div>
        <p class="mt-6 text-center text-xs uppercase tracking-[0.2em] text-slate-600">
          Control wraps the whole system
        </p>
      </div>
    </div>

    <figure class="mt-12">
      <div class="overflow-hidden rounded-2xl border border-white/10 bg-[#05080d] shadow-[0_24px_60px_rgba(0,0,0,0.45)]">
        <img
          src="/images/admin/dashboard.png"
          alt="ThinkWork admin dashboard showing agents online, open threads, recent activity, and recent threads for a tenant"
          loading="lazy"
          class="block h-auto w-full"
        />
      </div>
      <figcaption class="mt-3 text-center text-xs uppercase tracking-[0.2em] text-slate-600">
        {systemModel.dashboardCaption}
      </figcaption>
    </figure>
  </div>
</section>
