---
import SectionShell from "./SectionShell.astro";
import SectionHeader from "./SectionHeader.astro";
import ScreenshotFrame from "./ScreenshotFrame.astro";
import { systemModel } from "../lib/copy";
---

<SectionShell id="system" tone="raised" glow="top">
  <SectionHeader
    eyebrow={systemModel.eyebrow}
    headline={systemModel.headline}
    lede={systemModel.lede}
    width="widest"
  />

  <div class="relative mt-14 rounded-3xl border border-brand/15 bg-brand/[0.025] p-5 md:p-7">
    <div class="mb-5 flex items-center justify-between text-[11px] font-semibold uppercase tracking-[0.2em]">
      <span class="flex items-center gap-2 text-brand/85">
        <span class="h-1 w-1 rounded-full bg-brand"></span>
        {systemModel.controlLabel}
      </span>
      <span class="font-mono text-[10px] normal-case tracking-[0.18em] text-slate-500">
        {systemModel.controlDetail}
      </span>
    </div>

    <div class="grid gap-3 md:grid-cols-4">
      {systemModel.nodes.map((n, i) => (
        <div class="relative rounded-2xl border border-white/10 bg-[#0a0f16] p-6 transition hover:border-brand/25">
          <div class="flex items-center gap-2 text-[11px] font-mono tracking-[0.18em] text-brand/60">
            <span>0{i + 1}</span>
            <span class="h-px flex-1 bg-white/10"></span>
          </div>
          <h3 class="mt-3 text-[17px] font-semibold text-slate-100">{n.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-400">{n.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="mt-16">
    <ScreenshotFrame
      src="/images/admin/dashboard.png"
      alt="ThinkWork admin dashboard showing agents online, open threads, recent activity, and recent threads for a tenant"
      caption={systemModel.dashboardCaption}
      chromeLabel="admin · overview"
    />
  </div>
</SectionShell>
