---
import { finalCta as defaultFinalCta } from "../lib/copy";

interface Props {
  // When true, drops the top border + gradient divider and reduces top
  // padding so the CTA flows out of a tight preceding section without
  // a visible seam. Used on /cloud where the plans block ends close to
  // the CTA and the default divider reads as dead space.
  tight?: boolean;
  // Optional content override — used by /cloud to swap in
  // fully-hosted framing without affecting the homepage's
  // self-managed "your AWS, your rules" positioning.
  copy?: typeof defaultFinalCta;
}

const { tight = false, copy } = Astro.props;
const finalCta = copy ?? defaultFinalCta;
---

<section
  class:list={[
    "relative overflow-visible",
    tight
      ? "pb-28 pt-12 md:pb-36 md:pt-16"
      : "border-t border-white/5 py-28 md:py-36",
  ]}
>
  <div class="pointer-events-none absolute inset-x-0 -top-32 -bottom-24 overflow-hidden">
    <div class="absolute left-1/2 top-[12%] h-[340px] w-[760px] -translate-x-1/2 rounded-full bg-brand/8 blur-[150px]"></div>
    <div class="absolute left-1/2 bottom-[-10%] h-[320px] w-[900px] -translate-x-1/2 rounded-full bg-brand/6 blur-[160px]"></div>
    {!tight && (
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand/25 to-transparent"></div>
    )}
  </div>
  <div class="relative mx-auto max-w-5xl px-6 text-center">
    <p class="inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-1.5 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-300 backdrop-blur">
      {finalCta.eyebrow}
    </p>
    <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight md:text-6xl">
      {finalCta.headlinePart1} <span class="text-brand">{finalCta.headlineAccent}</span>
    </h2>
    <p class="mx-auto mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-slate-400 md:text-xl">
      {finalCta.lede}
    </p>
    <ul class="mx-auto mt-10 grid max-w-3xl grid-cols-2 gap-x-4 gap-y-4 sm:grid-cols-3 md:grid-cols-5">
      {finalCta.points.map((p) => (
        <li class="flex flex-col items-center gap-1 text-center">
          <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-brand/60">{p.title}</p>
          <p class="text-xs leading-5 text-slate-500">{p.desc}</p>
        </li>
      ))}
    </ul>
    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href={finalCta.primaryCta.href}
        class="rounded-xl bg-brand px-7 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-brand/20 transition hover:scale-[1.02] hover:bg-brand-300"
      >
        {finalCta.primaryCta.label}
      </a>
      <a
        href={finalCta.secondaryCta.href}
        class="rounded-xl border border-white/10 bg-white/[0.03] px-7 py-3 text-sm font-semibold text-slate-100 transition hover:border-white/20 hover:bg-white/[0.06]"
      >
        {finalCta.secondaryCta.label}
      </a>
    </div>
  </div>
</section>
