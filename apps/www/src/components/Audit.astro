---
import CapabilityShowcase from "./CapabilityShowcase.astro";
import { audit } from "../lib/copy";
---

<CapabilityShowcase
  id="audit"
  tone="raised"
  eyebrow={audit.eyebrow}
  headline={audit.headline}
  lede={audit.lede}
  features={audit.features}
  imagePath={audit.imagePath}
  imageAlt="ThinkWork admin thread detail for CHAT-102 showing the user prompt, a chat-message turn with its tool call and response step, turn-level token count, duration, cost, and agent attribution to Marco"
  caption={audit.caption}
  chromeLabel="admin · thread detail"
  accent
/>
