---
import SectionShell from "./SectionShell.astro";
import SectionHeader from "./SectionHeader.astro";
import { quickStart } from "../lib/copy";
---

<SectionShell id="quick-start" tone="raised">
  <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
    <div class="lg:col-span-5">
      <SectionHeader
        eyebrow={quickStart.eyebrow}
        headline={quickStart.headline}
        lede={quickStart.lede}
      />
      <a
        href={quickStart.ctaHref}
        class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/[0.04] px-5 py-3 text-sm font-semibold text-slate-100 transition hover:border-brand/30 hover:bg-white/[0.08]"
      >
        {quickStart.ctaLabel}
        <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>

    <div class="lg:col-span-7">
      <div class="overflow-hidden rounded-2xl border border-white/10 bg-[#05080d] shadow-[0_24px_60px_rgba(0,0,0,0.45)]">
        <div class="flex items-center gap-2 border-b border-white/5 bg-white/[0.02] px-4 py-2.5">
          <span class="h-2.5 w-2.5 rounded-full bg-red-500/50"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/50"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-green-500/50"></span>
          <span class="ml-3 font-mono text-[11px] text-slate-500">~ / thinkwork</span>
        </div>
        <pre class="overflow-x-auto px-6 py-7 font-mono text-[13px] leading-7 text-slate-300"><code>{quickStart.commands.map((c) => (
<span class="block"><span class="mr-4 select-none text-slate-600">{c.n}</span><span class="text-brand">$</span> <span>{c.text}</span></span>
))}</code></pre>
      </div>
    </div>
  </div>
</SectionShell>
