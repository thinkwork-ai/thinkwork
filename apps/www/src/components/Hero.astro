---
import BrainMark from "./BrainMark.astro";
import { hero } from "../lib/copy";
---

<section class="relative overflow-visible pt-28 pb-24 md:pt-36 md:pb-32">
  <div class="pointer-events-none absolute inset-x-0 -top-24 -bottom-32 overflow-hidden">
    <div class="absolute left-1/2 top-[-6%] h-[720px] w-[1200px] -translate-x-1/2 rounded-full bg-brand/8 blur-[160px]"></div>
    <div class="absolute left-1/2 top-[30%] h-[480px] w-[880px] -translate-x-1/2 rounded-full bg-brand/10 blur-[140px]"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-5xl text-center">
      <div class="animate-fade-in-up mb-8 flex justify-center">
        <BrainMark class="text-brand drop-shadow-[0_0_40px_rgba(56,189,248,0.35)]" size={120} title="ThinkWork" />
      </div>
      <p class="animate-fade-in-up inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-1.5 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-300 backdrop-blur">
        <span class="h-1 w-1 rounded-full bg-brand"></span>
        {hero.eyebrow}
      </p>
      <h1 class="animate-fade-in-up delay-100 mt-8 text-balance text-4xl font-extrabold leading-[1.05] tracking-tight md:text-6xl lg:text-7xl">
        {hero.headlinePart1}<br class="hidden md:inline" />
        <span class="text-brand"> {hero.headlineAccent}</span>
      </h1>
      <p class="animate-fade-in-up delay-200 mx-auto mt-7 max-w-3xl text-pretty text-lg leading-relaxed text-slate-400 md:text-xl">
        {hero.lede}
      </p>
      <p class="animate-fade-in-up delay-200 mx-auto mt-5 max-w-2xl text-pretty text-sm leading-relaxed text-slate-500 md:text-base">
        {hero.thirdOption}
      </p>
      <div class="animate-fade-in-up delay-300 mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={hero.primaryCta.href}
          class="rounded-xl bg-brand px-7 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-brand/20 transition hover:scale-[1.02] hover:bg-brand-300"
        >
          {hero.primaryCta.label}
        </a>
        <a
          href={hero.secondaryCta.href}
          class="rounded-xl border border-white/10 bg-white/[0.03] px-7 py-3 text-sm font-semibold text-slate-100 transition hover:border-white/20 hover:bg-white/[0.06]"
        >
          {hero.secondaryCta.label}
        </a>
      </div>
    </div>
  </div>
</section>
