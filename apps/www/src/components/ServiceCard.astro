---
// One service package rendered as a card on /services. Since the 2026-04-24
// Cloud/Services IA split, every card uses the same visual treatment — the
// earlier featured/secondary variant distinction was removed. Cards are
// informational; intake is handled by the shared hero + closing CTAs on
// the page. The single exception is Cloud Hosting, which opts into a
// visible CTA via ctaHref + ctaLabel — that card hands off to /cloud
// rather than the services intake inbox.

interface Props {
  id: string;
  name: string;
  type: "Fixed-fee" | "Ongoing operations";
  timeline: string;
  oneLiner: string;
  body: string;
  includes: string[];
  outcome: string;
  bestFor: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  id,
  name,
  type,
  timeline,
  oneLiner,
  body,
  includes,
  outcome,
  bestFor,
  ctaHref,
  ctaLabel,
} = Astro.props;

const isOngoing = type === "Ongoing operations";
---

<article
  data-service-id={id}
  class="relative flex h-full flex-col rounded-3xl border border-brand/30 bg-gradient-to-b from-brand/[0.08] to-white/[0.03] p-8 shadow-[0_0_80px_-30px] shadow-brand/25 backdrop-blur-xl transition"
>
  <header class="mb-5">
    <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
      <span
        class:list={[
          "inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.2em]",
          isOngoing
            ? "border-brand/40 bg-brand/[0.12] text-brand"
            : "border-white/15 bg-white/[0.04] text-slate-300",
        ]}
      >
        <span
          class:list={[
            "h-1 w-1 rounded-full",
            isOngoing ? "bg-brand" : "bg-slate-400",
          ]}
        ></span>
        {type}
      </span>
      <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-400">
        Timeline · <span class="text-slate-200">{timeline}</span>
      </span>
    </div>
    <h3 class="mt-4 text-2xl font-semibold tracking-tight text-slate-50">
      {name}
    </h3>
    <p class="mt-2 text-base font-medium text-slate-300">
      {oneLiner}
    </p>
    <p class="mt-3 text-sm leading-relaxed text-slate-400">
      {body}
    </p>
  </header>

  <ul class="mb-6 space-y-2.5">
    {includes.map((item) => (
      <li class="flex gap-2.5 text-[13px] text-slate-300">
        <svg
          class="mt-0.5 h-3.5 w-3.5 flex-none text-brand"
          viewBox="0 0 16 16"
          aria-hidden="true"
        >
          <path
            fill="currentColor"
            d="M6.5 11.793 3.354 8.646a.5.5 0 0 1 .708-.708L6.5 10.379l5.44-5.44a.5.5 0 1 1 .708.708l-5.793 5.792a.5.5 0 0 1-.707 0z"
          />
        </svg>
        <span>{item}</span>
      </li>
    ))}
  </ul>

  <div class="border-t border-white/5 pt-4">
    <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-400">
      Outcome
    </p>
    <p class="mt-1.5 text-[12px] leading-5 text-slate-300">
      {outcome}
    </p>
  </div>

  <div class="mt-4 border-t border-white/5 pt-4">
    <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-400">
      Best for
    </p>
    <p class="mt-1.5 text-[12px] leading-5 text-slate-500">
      {bestFor}
    </p>
  </div>

  {ctaHref && ctaLabel && (
    <div class="mt-auto pt-6">
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 rounded-xl border border-brand/40 bg-brand/[0.12] px-4 py-2 text-sm font-semibold text-brand transition hover:border-brand hover:bg-brand/[0.18]"
      >
        {ctaLabel}
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  )}
</article>
