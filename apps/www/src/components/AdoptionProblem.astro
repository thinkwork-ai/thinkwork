---
import { adoption } from "../lib/copy";
---

<section id="adoption" class="border-t border-white/5">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-brand/90">{adoption.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-5xl">
        {adoption.headline}
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-slate-400 md:text-xl">
        {adoption.lede}
      </p>

      <ul class="mt-10 grid gap-4 md:grid-cols-3">
        {adoption.bullets.map((b) => (
          <li class="rounded-2xl border border-white/5 bg-white/[0.02] p-6">
            <span class="text-sm leading-6 text-slate-300">{b}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
