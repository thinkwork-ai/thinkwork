---
import SectionShell from "./SectionShell.astro";
import SectionHeader from "./SectionHeader.astro";
import { adoption } from "../lib/copy";
---

<SectionShell id="adoption" glow="top">
  <SectionHeader
    eyebrow={adoption.eyebrow}
    headline={adoption.headline}
    lede={adoption.lede}
    width="wide"
  />

  <ul class="mt-14 grid gap-4 md:grid-cols-3">
    {adoption.bullets.map((b, i) => (
      <li class="group relative rounded-2xl border border-white/5 bg-white/[0.02] p-6 transition hover:border-white/10 hover:bg-white/[0.035]">
        <p class="font-mono text-[11px] tracking-[0.18em] text-brand/60">0{i + 1}</p>
        <p class="mt-4 text-sm leading-6 text-slate-300">{b}</p>
      </li>
    ))}
  </ul>
</SectionShell>
