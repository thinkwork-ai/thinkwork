---
import SectionShell from "./SectionShell.astro";
import SectionHeader from "./SectionHeader.astro";
import { howItWorks } from "../lib/copy";
---

<SectionShell id="how-it-works" tone="raised" glow="top">
  <SectionHeader
    eyebrow={howItWorks.eyebrow}
    headline={howItWorks.headline}
    lede={howItWorks.lede}
    align="center"
    width="wide"
  />

  <ul class="mt-14 grid gap-4 md:grid-cols-2">
    {howItWorks.primitives.map((p) => {
      const Wrapper = p.href ? "a" : "div";
      const wrapperProps = p.href
        ? {
            href: p.href,
            class:
              "block focus:outline-none focus-visible:ring-2 focus-visible:ring-brand/60 rounded-xl",
          }
        : { class: "block rounded-xl" };
      return (
        <li class="group relative rounded-2xl border border-white/5 bg-white/[0.02] p-7 transition hover:border-white/10 hover:bg-white/[0.035]">
          <Wrapper {...wrapperProps}>
            <h3 class="text-xl font-semibold text-slate-100">{p.title}</h3>
            <p class="mt-2 text-sm font-medium text-brand/90">{p.oneLiner}</p>
            <p class="mt-3 text-sm leading-6 text-slate-400">{p.detail}</p>
            {p.href && (
              <span class="mt-5 inline-flex items-center gap-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 transition group-hover:text-brand">
                See it <span aria-hidden="true">↓</span>
              </span>
            )}
          </Wrapper>
        </li>
      );
    })}
  </ul>
</SectionShell>
