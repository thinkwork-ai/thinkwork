---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SectionShell from "../components/SectionShell.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { services, servicesContactEmail } from "../lib/copy";

const heroPrimaryMailto = `mailto:${servicesContactEmail}?subject=${encodeURIComponent(
  services.hero.primaryCta.mailtoSubject,
)}`;
const closingPrimaryMailto = `mailto:${servicesContactEmail}?subject=${encodeURIComponent(
  services.closingCta.primaryCta.mailtoSubject,
)}`;

const featuredItems = services.packages.items.filter(
  (pkg) => pkg.variant === "featured",
);
const secondaryItems = services.packages.items.filter(
  (pkg) => pkg.variant === "secondary",
);
---

<Base title={services.meta.title} description={services.meta.description}>
  <Header />

  <main>
    {/* 1. Hero */}
    <SectionShell tone="default" glow="center">
      <div class="mx-auto max-w-4xl text-center">
        <p
          class="inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-1.5 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-300 backdrop-blur"
        >
          {services.hero.eyebrow}
        </p>
        <h1
          class="mt-8 text-balance text-4xl font-extrabold leading-[1.05] tracking-tight md:text-5xl lg:text-6xl"
        >
          {services.hero.headlinePart1}<br class="hidden md:inline" />{" "}
          <span class="text-brand">{services.hero.headlineAccent}</span>
        </h1>
        <p
          class="mx-auto mt-7 max-w-2xl text-balance text-lg font-medium leading-snug text-slate-200 md:text-xl"
        >
          {services.hero.headlineOutcome}
        </p>
        <p
          class="mx-auto mt-5 max-w-2xl text-pretty text-base leading-relaxed text-slate-400 md:text-lg"
        >
          {services.hero.lede}
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href={heroPrimaryMailto}
            class="rounded-xl bg-brand px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-brand/20 transition hover:scale-[1.02] hover:bg-brand-300"
          >
            {services.hero.primaryCta.label}
          </a>
          <a
            href={services.hero.secondaryCta.href}
            class="rounded-xl border border-white/15 bg-white/[0.04] px-6 py-3 text-sm font-semibold text-slate-100 transition hover:border-white/30 hover:bg-white/[0.08]"
          >
            {services.hero.secondaryCta.label}
          </a>
        </div>
      </div>
    </SectionShell>

    {/* 1b. Proof band — compact platform-credibility strip. Inline <section>, not SectionShell (SectionShell's py-24 is too tall for a supporting strip). */}
    <section class="relative border-t border-white/5 py-10 md:py-14">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand/25 to-transparent"></div>
      <div class="mx-auto max-w-6xl px-6">
        <p class="text-center font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-brand/70">
          {services.proof.eyebrow}
        </p>
        <div class="mt-6 grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2 md:grid-cols-4">
          {services.proof.items.map((item) => (
            <div class="flex flex-col gap-1.5">
              <p class="text-sm font-semibold tracking-tight text-slate-100">
                {item.label}
              </p>
              {item.detail && (
                <p class="text-xs leading-5 text-slate-500">{item.detail}</p>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* 2. Positioning */}
    <SectionShell tone="raised">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-balance text-3xl font-bold leading-[1.15] tracking-tight md:text-4xl">
          {services.positioning.headline}
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-slate-400">
          {services.positioning.body}
        </p>
      </div>

      <div class="mx-auto mt-14 max-w-6xl">
        <p class="text-center font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-brand/70">
          {services.positioning.startingPointsLabel}
        </p>
        <ul class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {services.positioning.startingPoints.map((point, index) => (
            <li class="group relative rounded-2xl bg-gradient-to-br from-brand/30 via-white/10 to-white/[0.02] p-[1px] transition duration-300 hover:from-brand/60 hover:via-brand/20 hover:to-white/[0.06]">
              <div class="relative flex h-full flex-col rounded-2xl bg-[#070b14] p-6">
                <div class="flex items-center justify-between">
                  <span class="font-mono text-[11px] font-semibold tracking-[0.18em] text-brand">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span class="h-1.5 w-1.5 rounded-full bg-brand/60 shadow-[0_0_12px_rgba(56,189,248,0.55)]"></span>
                </div>
                <h3 class="mt-5 text-lg font-semibold leading-snug tracking-tight text-white">
                  {point.title}
                </h3>
                <p class="mt-3 text-[13.5px] leading-relaxed text-slate-400">
                  {point.body}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </SectionShell>

    {/* 3. How it works — engagement lifecycle */}
    <SectionShell tone="default" glow="top">
      <SectionHeader
        eyebrow={services.how.eyebrow}
        headline={services.how.headline}
        lede={services.how.lede}
        align="center"
        width="wide"
      />
      <ol class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {services.how.steps.map((step) => (
          <li
            class="relative flex h-full flex-col rounded-2xl border border-white/10 bg-white/[0.02] p-6 backdrop-blur-xl"
          >
            <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.22em] text-brand/70">
              {step.n}
            </p>
            <h3 class="mt-3 text-lg font-semibold tracking-tight text-slate-50">
              {step.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">
              {step.body}
            </p>
          </li>
        ))}
      </ol>
    </SectionShell>

    {/* 4. Featured packages */}
    <SectionShell id="packages" tone="raised" glow="center">
      <SectionHeader
        eyebrow={services.packages.eyebrow}
        headline={services.packages.headline}
        lede={services.packages.lede}
        align="center"
        width="wide"
      />
      <div class="mt-14 grid gap-y-8 gap-x-5 md:gap-y-6 md:grid-cols-2 xl:grid-cols-4">
        {featuredItems.map((pkg) => (
          <ServiceCard
            id={pkg.id}
            name={pkg.name}
            type={pkg.type}
            timeline={pkg.timeline}
            oneLiner={pkg.oneLiner}
            body={pkg.body}
            includes={pkg.includes}
            outcome={pkg.outcome}
            bestFor={pkg.bestFor}
            variant={pkg.variant}
          />
        ))}
      </div>
    </SectionShell>

    {/* 5. Additional packages (secondary) */}
    <SectionShell tone="default">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-balance text-2xl font-semibold tracking-tight text-slate-100 md:text-3xl">
          {services.packages.secondaryHeadline}
        </h2>
        <p class="mt-4 text-sm leading-relaxed text-slate-400 md:text-base">
          {services.packages.secondaryLede}
        </p>
      </div>
      <div class="mx-auto mt-12 grid max-w-5xl gap-y-8 gap-x-5 md:gap-y-6 md:grid-cols-2">
        {secondaryItems.map((pkg) => (
          <ServiceCard
            id={pkg.id}
            name={pkg.name}
            type={pkg.type}
            timeline={pkg.timeline}
            oneLiner={pkg.oneLiner}
            body={pkg.body}
            includes={pkg.includes}
            outcome={pkg.outcome}
            bestFor={pkg.bestFor}
            variant={pkg.variant}
          />
        ))}
      </div>
    </SectionShell>

    {/* 6. FAQ */}
    <SectionShell tone="raised">
      <SectionHeader
        eyebrow={services.faq.eyebrow}
        headline={services.faq.headline}
        align="center"
        width="wide"
      />
      <div class="mx-auto mt-12 max-w-3xl divide-y divide-white/8">
        {services.faq.items.map((item) => (
          <article class="py-6 first:pt-0">
            <h3 class="text-lg font-semibold tracking-tight text-slate-100">
              {item.q}
            </h3>
            <p class="mt-3 text-[15px] leading-relaxed text-slate-400">
              {item.a}
            </p>
          </article>
        ))}
      </div>
    </SectionShell>

    {/* 9. Closing CTA — inlined; FinalCTA.astro has no props */}
    <section class="relative overflow-visible border-t border-white/5 py-28 md:py-36">
      <div
        class="pointer-events-none absolute inset-x-0 -top-32 -bottom-24 overflow-hidden"
      >
        <div
          class="absolute left-1/2 top-[12%] h-[340px] w-[760px] -translate-x-1/2 rounded-full bg-brand/8 blur-[150px]"
        ></div>
        <div
          class="absolute left-1/2 bottom-[-10%] h-[320px] w-[900px] -translate-x-1/2 rounded-full bg-brand/6 blur-[160px]"
        ></div>
        <div
          class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand/25 to-transparent"
        ></div>
      </div>
      <div class="relative mx-auto max-w-4xl px-6 text-center">
        <p
          class="inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-1.5 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-300 backdrop-blur"
        >
          {services.closingCta.eyebrow}
        </p>
        <h2 class="mt-6 text-balance text-3xl font-bold tracking-tight md:text-5xl lg:text-6xl">
          {services.closingCta.headlinePart1}{" "}
          <span class="text-brand">{services.closingCta.headlineAccent}</span>
        </h2>
        <p class="mx-auto mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-slate-400">
          {services.closingCta.body}
        </p>
        <div class="mt-10 flex justify-center">
          <a
            href={closingPrimaryMailto}
            class="rounded-xl bg-brand px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-brand/20 transition hover:scale-[1.02] hover:bg-brand-300"
          >
            {services.closingCta.primaryCta.label}
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
