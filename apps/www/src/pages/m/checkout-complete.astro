---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionShell from "../../components/SectionShell.astro";

// Mobile bounce page for the Stripe Checkout success redirect.
//
// Stripe requires an HTTPS success_url; the mobile app can't register a
// universal link without new Apple-team provisioning, so the mobile
// pricing screen opens Checkout with success_url set to this page and a
// literal-scheme redirectUri of thinkwork://onboarding/complete (matching
// the four other openAuthSessionAsync call sites in apps/mobile). This
// page reads ?session_id=... from the URL and immediately assigns
// window.location to the scheme URL — iOS ASWebAuthenticationSession
// intercepts and closes, handing control back to the Expo app.
//
// Fallbacks (in priority order):
//   1. JS fires and intercepts → user never visibly sees this page.
//   2. Scheme doesn't resolve (desktop browser, app not installed) →
//      a visible card with a "Return to app" button (same scheme href)
//      and a "sign in via web" escape hatch pointing at admin.
//
// noindex — this is a return page, no discovery value.
---

<Base
  title="Return to ThinkWork"
  description="Finishing your checkout. Redirecting you back to the ThinkWork app."
>
  <Header />

  <main>
    <SectionShell tone="default" glow="top">
      <div class="mx-auto max-w-2xl text-center">
        <p
          class="inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-1.5 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-300 backdrop-blur"
        >
          Payment received
        </p>
        <h1
          class="mt-8 text-balance text-3xl font-extrabold leading-[1.1] tracking-tight md:text-4xl"
        >
          Back to the ThinkWork app.
        </h1>
        <p class="mx-auto mt-6 max-w-lg text-sm leading-relaxed text-slate-400 md:text-base">
          We're redirecting you into the app to finish setup. If nothing
          happens in a moment, use the button below.
        </p>

        <div id="m-return-valid" class="mt-10 hidden">
          <a
            id="m-return-link"
            href="#"
            class="rounded-xl bg-brand px-7 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-brand/20 transition hover:scale-[1.02] hover:bg-brand-300"
          >
            Return to ThinkWork
          </a>
          <p class="mt-6 text-xs leading-relaxed text-slate-500">
            On a device without the ThinkWork app?
            <a
              id="m-return-web-fallback"
              href="https://admin.thinkwork.ai/onboarding/welcome"
              class="underline decoration-dotted hover:text-slate-300"
              >Finish setup on the web</a
            >
            instead.
          </p>
        </div>

        <div id="m-return-missing" class="mt-10 hidden">
          <p class="text-sm text-red-300">
            We couldn't find a checkout session in this URL. If you just
            completed a purchase, check your email for the receipt, or head
            back to pricing.
          </p>
          <div class="mt-6">
            <a
              href="/pricing"
              class="rounded-xl border border-white/15 bg-white/[0.04] px-7 py-3 text-sm font-semibold text-slate-100 transition hover:border-white/30 hover:bg-white/[0.08]"
            >
              Return to pricing
            </a>
          </div>
        </div>
      </div>
    </SectionShell>
  </main>

  <Footer />
</Base>

<!-- noindex — mobile return-only page -->
<meta slot="head" name="robots" content="noindex,nofollow" />

<script is:inline>
  (() => {
    const params = new URLSearchParams(window.location.search);
    const sessionId = params.get("session_id") || "";
    const valid = document.getElementById("m-return-valid");
    const missing = document.getElementById("m-return-missing");
    const link = document.getElementById("m-return-link");
    const webFallback = document.getElementById("m-return-web-fallback");

    if (!sessionId) {
      if (missing) missing.classList.remove("hidden");
      return;
    }

    const schemeUrl =
      "thinkwork://onboarding/complete?session_id=" +
      encodeURIComponent(sessionId) +
      "&paid=1";

    if (link) link.setAttribute("href", schemeUrl);
    if (webFallback) {
      webFallback.setAttribute(
        "href",
        "https://admin.thinkwork.ai/onboarding/welcome?session_id=" +
          encodeURIComponent(sessionId),
      );
    }
    if (valid) valid.classList.remove("hidden");

    // Fire the scheme. iOS ASWebAuthenticationSession intercepts on match
    // and closes the sheet back into the Expo app. On desktop this is a
    // no-op and the visible "Return to ThinkWork" button remains the
    // primary CTA.
    window.location.assign(schemeUrl);
  })();
</script>
