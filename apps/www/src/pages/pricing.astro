---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SectionShell from "../components/SectionShell.astro";
import SectionHeader from "../components/SectionHeader.astro";
import PricingGrid from "../components/PricingGrid.astro";
import FinalCTA from "../components/FinalCTA.astro";
import { pricing } from "../lib/copy";

// PUBLIC_API_URL is injected at build time by scripts/build-www.sh from the
// Terraform `api_endpoint` output (or the custom api.thinkwork.ai domain
// once it's wired). Defaults to the empty string when building locally
// without Terraform context — the page still renders, but the CTA
// disables with an inline error.
const PUBLIC_API_URL = import.meta.env.PUBLIC_API_URL ?? "";
---

<Base title={pricing.meta.title} description={pricing.meta.description}>
  <Header />

  <main>
    <SectionShell tone="default" glow="center">
      <div class="mx-auto max-w-4xl text-center">
        <p class="inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-white/[0.04] px-3.5 py-1.5 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-300 backdrop-blur">
          {pricing.eyebrow}
        </p>
        <h1 class="mt-8 text-balance text-4xl font-extrabold leading-[1.05] tracking-tight md:text-5xl lg:text-6xl">
          {pricing.headline}<br class="hidden md:inline" />
          <span class="text-brand"> {pricing.headlineAccent}</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-pretty text-base leading-relaxed text-slate-400 md:text-lg">
          {pricing.lede}
        </p>
      </div>

      <div class="mt-16">
        <PricingGrid />
      </div>
    </SectionShell>

    <FinalCTA />
  </main>

  <Footer />
</Base>

<script is:inline define:vars={{ PUBLIC_API_URL }}>
  (() => {
    const apiBase = (PUBLIC_API_URL || "").replace(/\/$/, "");
    const buttons = document.querySelectorAll("[data-plan-cta]");
    if (!buttons.length) return;

    buttons.forEach((button) => {
      const planId = button.getAttribute("data-plan-cta");
      const errorEl = document.querySelector(`[data-plan-error="${planId}"]`);

      function showError(message) {
        if (!errorEl) return;
        errorEl.textContent = message;
        errorEl.classList.remove("hidden");
      }

      function clearError() {
        if (!errorEl) return;
        errorEl.classList.add("hidden");
        errorEl.textContent = "";
      }

      button.addEventListener("click", async () => {
        if (!apiBase) {
          showError("Checkout isn't configured yet. Check back shortly or email hello@thinkwork.ai.");
          return;
        }

        clearError();
        const originalText = button.textContent;
        button.setAttribute("disabled", "true");
        button.textContent = "Starting checkout…";

        try {
          const res = await fetch(`${apiBase}/api/stripe/checkout-session`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ plan: planId }),
          });

          if (!res.ok) {
            const msg = await res.text().catch(() => "");
            throw new Error(`HTTP ${res.status}: ${msg || "Failed to start checkout"}`);
          }

          const data = await res.json();
          if (!data?.url) {
            throw new Error("No checkout URL returned");
          }
          window.location.assign(data.url);
        } catch (err) {
          console.error("[pricing] Checkout failed", err);
          showError("Could not start checkout. Please retry, or email hello@thinkwork.ai.");
          button.removeAttribute("disabled");
          button.textContent = originalText;
        }
      });
    });
  })();
</script>
