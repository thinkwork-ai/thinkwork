---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import AdoptionJourney from "../components/AdoptionJourney.astro";
import HowItWorks from "../components/HowItWorks.astro";
import FiveControls from "../components/FiveControls.astro";
import AgentTemplates from "../components/AgentTemplates.astro";
import Audit from "../components/Audit.astro";
import CostControl from "../components/CostControl.astro";
import MemoryWedge from "../components/MemoryWedge.astro";
import MobileApp from "../components/MobileApp.astro";
import QuickStart from "../components/QuickStart.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
import { meta } from "../lib/copy";
---

<Base title={meta.title} description={meta.description}>
  <Header />
  <main class="overflow-x-clip">
    <Hero />
    <FiveControls />
    <Audit />
    <HowItWorks />
    <MemoryWedge />
    <AdoptionJourney />
    <AgentTemplates />
    <CostControl />
    <MobileApp />
    <QuickStart />
    <FinalCTA />
  </main>
  <Footer />
</Base>
