# apps/web dev env. Mirror values from your dev stack's Terraform outputs
# (the same set scripts/build-web.sh writes for apps/web/.env.production).
#
# Run `pnpm --filter @thinkwork/web dev` after copying this to .env.local.
# Cognito sign-in requires `http://localhost:5180` and
# `http://localhost:5180/auth/callback` to be in the ThinkworkAdmin
# Cognito client's CallbackURLs / LogoutURLs — manual tfvars edit until the
# infra slice ships that change.

VITE_API_URL=
VITE_GRAPHQL_HTTP_URL=
VITE_GRAPHQL_URL=
VITE_GRAPHQL_WS_URL=
VITE_GRAPHQL_API_KEY=
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
VITE_AUTH_IDENTITY_PROVIDERS=Google
VITE_DEPLOYMENT_ID=
VITE_DEPLOYMENT_DISPLAY_NAME=
VITE_STAGE=
VITE_AWS_REGION=
VITE_SPACES_URL=

# --- Generated-app (Applet/Artifact) iframe sandbox -------------------------
# Artifacts render inside a cross-origin sandbox iframe loaded from
# VITE_SANDBOX_IFRAME_SRC (default in dev: http://localhost:5175/iframe-shell.html).
# The iframe-shell only accepts postMessages from parent origins baked into its
# bundle at build time (VITE_ALLOWED_PARENT_ORIGINS). If the running app's origin
# isn't in that list the handshake is silently dropped and the artifact stays on
# the loading shimmer (then errors out after the watchdog timeout naming the
# origin). To preview artifacts locally, in a second terminal run:
#
#   pnpm --filter @thinkwork/web dev:iframe-shell
#
# which builds the shell with a permissive local allowlist (web :5180/:5174 and
# the desktop thinkwork:// schemes) and serves it on :5175 with CORS. Override
# either var here if your app runs on a different origin/port.
# VITE_SANDBOX_IFRAME_SRC=http://localhost:5175/iframe-shell.html
# VITE_ALLOWED_PARENT_ORIGINS=http://localhost:5180,thinkwork://app
